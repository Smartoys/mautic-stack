# All env variables are defined in the Git repository
# No Env variables must be defined in Portainer
COMPOSE_PROJECT_NAME=mautic-dlgamer
COMPOSE_NETWORK=${COMPOSE_PROJECT_NAME}-docker
MYSQL_HOST=percona-db
MYSQL_PORT=3306
MYSQL_DATABASE=mautic_db_dlgamer
MYSQL_USER=mautic_user_dlgamer
# MYSQL_PASSWORD should be set to a long secure alphanumeric sequence
MYSQL_PASSWORD=CHANGE_ME
# MYSQL_ROOT_PASSWORD should be set to a long secure alphanumeric sequence
MYSQL_ROOT_PASSWORD=CHANGE_ME
RABBITMQ_DEFAULT_VHOST=mautic
DOCKER_MAUTIC_LOAD_TEST_DATA=false
DOCKER_MAUTIC_RUN_MIGRATIONS=false
