# use this file for environment variables that can be used.
# see https://docs.mautic.org/en/5.x/

MAUTIC_DB_HOST="${MYSQL_HOST}"
MAUTIC_DB_PORT="${MYSQL_PORT}"
MAUTIC_DB_DATABASE="${MYSQL_DATABASE}"
MAUTIC_DB_USER="${MYSQL_USER}"
MAUTIC_DB_PASSWORD="${MYSQL_PASSWORD}"
MAUTIC_CONFIG_DEBUG=1
PHP_INI_VALUE_MEMORY_LIMIT=2G
PHP_INI_VALUE_MAX_EXECUTION_TIME=3600
PHP_INI_VALUE_LOG_ERRORS=On
PHP_INI_VALUE_ERROR_LOG=/dev/stdout
DOCKER_MAUTIC_LOAD_TEST_DATA=False 

# commented causes php bin/console mautic:update:apply --finish to fail
#MAUTIC_MESSENGER_DSN_EMAIL="amqp://guest:guest@rabbitmq:5672/mautic/messages"
#MAUTIC_MESSENGER_DSN_HIT="amqp://guest:guest@rabbitmq:5672/mautic/messages"
